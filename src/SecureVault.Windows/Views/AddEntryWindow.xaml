<Window x:Class="SecureVault.Windows.Views.AddEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить запись" Icon="/Assets/app.ico" SizeToContent="Height" MaxHeight="750" Width="460" MinWidth="400"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24">
            <TextBlock Text="Название" Style="{StaticResource FieldLabelStyle}"/>
            <TextBox x:Name="TitleTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Теги (через запятую)" Style="{StaticResource FieldLabelStyle}"/>
            <TextBox x:Name="TagsTextBox" Margin="0,0,0,14"/>

            <TabControl x:Name="TypeTabControl" SelectionChanged="OnTypeTabControlSelectionChanged">
                <TabItem Header="Логин">
                    <StackPanel Margin="0,14,0,0">
                        <TextBlock Text="Логин/имя пользователя" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="UsernameTextBox" Margin="0,0,0,10"/>
                        <TextBlock Text="Пароль" Style="{StaticResource FieldLabelStyle}"/>
                        <PasswordBox x:Name="LoginPasswordBox" Margin="0,0,0,10"/>
                        <TextBlock Text="URL" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="UrlTextBox" Margin="0,0,0,10"/>
                        <TextBlock Text="Заметки" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="LoginNotesTextBox" AcceptsReturn="True" Height="40"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="Заметка">
                    <StackPanel Margin="0,14,0,0">
                        <TextBlock Text="Текст заметки" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="NoteBodyTextBox" AcceptsReturn="True" TextWrapping="Wrap" Height="165"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="Файл">
                    <StackPanel Margin="0,14,0,0">
                        <Button Content="Выбрать файлы..." HorizontalAlignment="Left" Click="OnBrowseFileClick"/>
                        <TextBlock Text="Можно выбрать несколько файлов; для изображений показывается превью." Style="{StaticResource HintTextStyle}" Margin="0,8,0,8"/>
                        <ListBox x:Name="SelectedFilesListBox" Height="150" BorderThickness="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Image Grid.Column="0" Source="{Binding Thumbnail}" Width="32" Height="32" Margin="0,0,10,0"
                                               Stretch="UniformToFill" Visibility="{Binding ThumbnailVisibility}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding DisplayText}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="2" Content="✕" Style="{StaticResource IconButtonStyle}" Click="OnRemoveFileClick" ToolTip="Убрать файл"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </TabItem>
            </TabControl>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Отмена" Margin="0,0,8,0" Click="OnCancelClick"/>
                <Button Content="Сохранить" Style="{StaticResource AccentButtonStyle}" Click="OnSaveClick"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
