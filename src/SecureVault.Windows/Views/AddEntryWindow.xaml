<Window x:Class="SecureVault.Windows.Views.AddEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить запись" Height="480" Width="440" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16">
        <TextBlock Text="Название" Margin="0,0,0,4"/>
        <TextBox x:Name="TitleTextBox" Margin="0,0,0,8"/>

        <TextBlock Text="Теги (через запятую)" Margin="0,0,0,4"/>
        <TextBox x:Name="TagsTextBox" Margin="0,0,0,12"/>

        <TabControl x:Name="TypeTabControl" Height="220">
            <TabItem Header="Логин">
                <StackPanel Margin="8">
                    <TextBlock Text="Логин/имя пользователя" Margin="0,0,0,4"/>
                    <TextBox x:Name="UsernameTextBox" Margin="0,0,0,8"/>
                    <TextBlock Text="Пароль" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="LoginPasswordBox" Margin="0,0,0,8"/>
                    <TextBlock Text="URL" Margin="0,0,0,4"/>
                    <TextBox x:Name="UrlTextBox" Margin="0,0,0,8"/>
                    <TextBlock Text="Заметки" Margin="0,0,0,4"/>
                    <TextBox x:Name="LoginNotesTextBox" AcceptsReturn="True" Height="40"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Заметка">
                <StackPanel Margin="8">
                    <TextBlock Text="Текст заметки" Margin="0,0,0,4"/>
                    <TextBox x:Name="NoteBodyTextBox" AcceptsReturn="True" TextWrapping="Wrap" Height="150"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Файл">
                <StackPanel Margin="8">
                    <Button Content="Выбрать файл..." Padding="8,4" HorizontalAlignment="Left" Click="OnBrowseFileClick"/>
                    <TextBlock x:Name="FileNameText" Text="файл не выбран" Margin="0,8,0,0"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Padding="10,4" Margin="0,0,8,0" Click="OnCancelClick"/>
            <Button Content="Сохранить" Padding="10,4" Click="OnSaveClick"/>
        </StackPanel>
    </StackPanel>
</Window>
