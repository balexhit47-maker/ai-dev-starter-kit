<Window x:Class="SecureVault.Windows.Views.CreateVaultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый сейф" Height="420" Width="420" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock Text="Имя сейфа" Margin="0,0,0,4"/>
        <TextBox x:Name="NameTextBox" Margin="0,0,0,12"/>

        <TextBlock Text="Мастер-пароль" Margin="0,0,0,4"/>
        <PasswordBox x:Name="PasswordBox" Margin="0,0,0,12"/>

        <TextBlock Text="Повторите пароль" Margin="0,0,0,4"/>
        <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,0,0,12"/>

        <TextBlock Text="Файл-ключ (выбирается заново при каждом входе, путь нигде не сохраняется)" TextWrapping="Wrap" Margin="0,0,0,4"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Выбрать файл..." Padding="8,4" Click="OnBrowseKeyfileClick"/>
            <TextBlock x:Name="KeyfileNameText" Text="файл не выбран" VerticalAlignment="Center" Margin="8,0,0,0"/>
        </StackPanel>

        <CheckBox x:Name="NoRecoveryCheckBox" Margin="0,0,0,16" IsChecked="False">
            <TextBlock TextWrapping="Wrap" Text="Я понимаю, что при потере мастер-пароля или файла-ключа восстановить данные невозможно."/>
        </CheckBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Padding="10,4" Margin="0,0,8,0" Click="OnCancelClick"/>
            <Button Content="Создать" Padding="10,4" Click="OnCreateClick"/>
        </StackPanel>
    </StackPanel>
</Window>
