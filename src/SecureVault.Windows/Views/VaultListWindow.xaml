<Window x:Class="SecureVault.Windows.Views.VaultListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SecureVault" Height="460" Width="520" WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Сейфы" Style="{StaticResource PageHeadingStyle}"/>

        <ListBox x:Name="VaultsListBox" Grid.Row="1"
                 DisplayMemberPath="FileName"
                 MouseDoubleClick="OnVaultsListBoxMouseDoubleClick"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Синхронизация..." Margin="0,0,8,0" Click="OnSyncClick"/>
            <Button Content="Открыть" Margin="0,0,8,0" Click="OnOpenClick"/>
            <Button Content="Новый сейф..." Style="{StaticResource AccentButtonStyle}" Click="OnNewVaultClick"/>
        </StackPanel>
    </Grid>
</Window>
