<Window x:Class="SecureVault.Windows.Views.VaultListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="cryptoAll" Icon="/Assets/app.ico" Height="500" Width="560" MinHeight="400" MinWidth="480" WindowStartupLocation="CenterScreen"
        SourceInitialized="OnSourceInitialized">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Сейфы" Style="{StaticResource PageHeadingStyle}"/>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Папка хранения" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,2"/>
                <TextBlock x:Name="StorageFolderText" Style="{StaticResource HintTextStyle}" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Открыть папку" Margin="8,0,0,0" VerticalAlignment="Bottom" Click="OnOpenFolderClick"/>
            <Button Grid.Column="2" Content="Изменить..." Margin="8,0,0,0" VerticalAlignment="Bottom" Click="OnChangeFolderClick"/>
        </Grid>

        <ListBox x:Name="VaultsListBox" Grid.Row="2"
                 DisplayMemberPath="FileName"
                 MouseDoubleClick="OnVaultsListBoxMouseDoubleClick"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Удалить сейф" Style="{StaticResource DangerButtonStyle}" Margin="0,0,8,0" Click="OnDeleteVaultClick"/>
            <Button Content="Синхронизация..." Margin="0,0,8,0" Click="OnSyncClick"/>
            <Button Content="Открыть" Margin="0,0,8,0" Click="OnOpenClick"/>
            <Button Content="Новый сейф..." Style="{StaticResource AccentButtonStyle}" Click="OnNewVaultClick"/>
        </StackPanel>
    </Grid>
</Window>
