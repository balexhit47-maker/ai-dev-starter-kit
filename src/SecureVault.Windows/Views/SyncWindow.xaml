<Window x:Class="SecureVault.Windows.Views.SyncWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Синхронизация" Height="420" Width="440" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16">
        <TextBlock Text="Яндекс.Диск (WebDAV)" FontWeight="Bold" Margin="0,0,0,8"/>
        <TextBlock Text="Логин" Margin="0,0,0,4"/>
        <TextBox x:Name="WebDavLoginTextBox" Margin="0,0,0,8"/>
        <TextBlock Text="Пароль приложения (не сохраняется)" Margin="0,0,0,4"/>
        <PasswordBox x:Name="WebDavPasswordBox" Margin="0,0,0,8"/>
        <TextBlock Text="Путь на Диске (например: SecureVault/personal.vault)" Margin="0,0,0,4"/>
        <TextBox x:Name="WebDavPathTextBox" Margin="0,0,0,8"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="Загрузить сейф на Диск..." Padding="8,4" Margin="0,0,8,0" Click="OnWebDavUploadClick"/>
            <Button Content="Скачать с Диска" Padding="8,4" Click="OnWebDavDownloadClick"/>
        </StackPanel>

        <Separator Margin="0,0,0,16"/>

        <TextBlock Text="Импорт по ссылке" FontWeight="Bold" Margin="0,0,0,8"/>
        <TextBlock Text="Публичная ссылка Яндекс.Диска (disk.yandex.ru/d/... или yadi.sk/d/...)" TextWrapping="Wrap" Margin="0,0,0,4"/>
        <TextBox x:Name="LinkUrlTextBox" Margin="0,0,0,8"/>
        <Button Content="Импортировать" HorizontalAlignment="Left" Padding="8,4" Click="OnImportLinkClick"/>

        <TextBlock x:Name="StatusText" Margin="0,16,0,0" TextWrapping="Wrap" Foreground="DarkSlateGray"/>
    </StackPanel>
</Window>
