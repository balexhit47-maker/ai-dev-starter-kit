<Window x:Class="SecureVault.Windows.Views.MainVaultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SecureVault" Height="480" Width="600" WindowStartupLocation="CenterScreen"
        Closing="OnClosing" StateChanged="OnStateChanged">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Grid.Row="0" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

        <ListView x:Name="EntriesListView" Grid.Row="1" MouseDoubleClick="OnEntriesListViewMouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Название" Width="260" DisplayMemberBinding="{Binding Title}"/>
                    <GridViewColumn Header="Тип" Width="100" DisplayMemberBinding="{Binding Type}"/>
                    <GridViewColumn Header="Изменено" Width="160" DisplayMemberBinding="{Binding ModifiedAt}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Удалить" Padding="10,4" Margin="0,0,8,0" Click="OnDeleteClick"/>
            <Button Content="Открыть" Padding="10,4" Margin="0,0,8,0" Click="OnOpenClick"/>
            <Button Content="Добавить..." Padding="10,4" Click="OnAddClick"/>
        </StackPanel>
    </Grid>
</Window>
